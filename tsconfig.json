{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "moduleResolution": "Node16",

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}